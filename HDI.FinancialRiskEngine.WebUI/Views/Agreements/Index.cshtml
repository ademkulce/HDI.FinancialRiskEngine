@model List<HDI.FinancialRiskEngine.Application.DTOs.Agreements.AgreementListDto>

@{
    ViewData["Title"] = "Agreements";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Anlaşmalar</h2>
        <a href="Agreements/Create" class="btn btn-primary">Yeni Anlaşma</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Kod</th>
                                <th>Ad</th>
                                <th>Açıklama</th>
                                <th>Başlangıç</th>
                                <th>Bitiş</th>
                                <th>Risk Oranı</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Code</td>
                                    <td>@item.Name</td>
                                    <td>@item.Description</td>
                                    <td>@item.StartDate.ToString("dd.MM.yyyy")</td>
                                    <td>@(item.EndDate.HasValue? item.EndDate.Value.ToString("dd.MM.yyyy") : "-")</td>
                                    <td>@item.BaseRiskRate.ToString("N2")</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Pasif</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    Henüz anlaşma kaydı bulunmuyor.
                </div>
            }
        </div>
    </div>
</div>
