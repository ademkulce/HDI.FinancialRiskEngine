@model HDI.FinancialRiskEngine.Application.DTOs.BusinessTopics.CreateBusinessTopicDto

@{
    ViewData["Title"] = "Yeni İş Konusu";
}

<div class="container mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="mb-4">Yeni İş Konusu</h2>

                <form action="/BusinessTopics/Create" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="TenantId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Anlaşma</label>
                        <select asp-for="AgreementId" class="form-select" asp-items="ViewBag.Agreements">
                            <option value="">Seçiniz</option>
                        </select>
                        <span asp-validation-for="AgreementId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">İş Ortağı</label>
                        <select asp-for="BusinessPartnerId" class="form-select" asp-items="ViewBag.BusinessPartners">
                            <option value="">Seçiniz</option>
                        </select>
                        <span asp-validation-for="BusinessPartnerId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Başlık</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Referans No</label>
                        <input asp-for="ReferenceNumber" class="form-control" />
                        <span asp-validation-for="ReferenceNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Konu Tarihi</label>
                        <input asp-for="TopicDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="TopicDate" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Raw Payload</label>
                        <textarea asp-for="RawPayload" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="RawPayload" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Kaydet</button>
                    <a href="/BusinessTopics/Index" class="btn btn-secondary">Geri</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
