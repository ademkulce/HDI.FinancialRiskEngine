@model HDI.FinancialRiskEngine.WebUI.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";

}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Toplam Anlaşma</h6>
                    <h2 class="fw-bold">@Model.TotalAgreements</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Toplam İş Ortağı</h6>
                    <h2 class="fw-bold">@Model.TotalBusinessPartners</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Toplam İş Konusu</h6>
                    <h2 class="fw-bold">@Model.TotalBusinessTopics</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Analiz Edilen Konu</h6>
                    <h2 class="fw-bold">@Model.TotalAnalyzedTopics</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">Son Eklenen İş Konuları</h5>

                    @if (Model.RecentBusinessTopics != null && Model.RecentBusinessTopics.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Başlık</th>
                                        <th>Referans No</th>
                                        <th>Tarih</th>
                                        <th>Durum</th>
                                        <th>Risk Tutarı</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.RecentBusinessTopics)
                                    {
                                        <tr>
                                            <td>@item.Title</td>
                                            <td>@item.ReferenceNumber</td>
                                            <td>@item.TopicDate.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td>
                                                @if (item.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                }
                                                else if (item.Status == "Analyzed")
                                                {
                                                    <span class="badge bg-info text-dark">Analyzed</span>
                                                }
                                                else if (item.Status == "Completed")
                                                {
                                                    <span class="badge bg-success">Completed</span>
                                                }
                                                else if (item.Status == "Rejected")
                                                {
                                                    <span class="badge bg-danger">Rejected</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@item.Status</span>
                                                }
                                            </td>
                                            <td>
                                                @(item.CalculatedRiskAmount.HasValue ? item.CalculatedRiskAmount.Value.ToString("N2") : "-")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            Henüz gösterilecek iş konusu kaydı bulunmuyor.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title mb-3">Risk Seviyesi Dağılımı</h5>
                <canvas id="riskChart" height="100"></canvas>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const ctx = document.getElementById('riskChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Low', 'Medium', 'High', 'Critical'],
                datasets: [{
                    label: 'Risk Adedi',
                    data: [
                        @Model.LowRiskCount,
                        @Model.MediumRiskCount,
                        @Model.HighRiskCount,
                        @Model.CriticalRiskCount
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });
    </script>
}